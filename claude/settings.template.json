        "matcher": "mcp__sap-adt__adt_(push_source|activate|dtel_create|domain_create|struct_create|publish_service)",
        "hooks": [ { "type": "command", "command": "python", "args": ["${CLAUDE_PROJECT_DIR}/scripts/hook_shim.py", "sap_worktype_hint"] } ]
      },
      {
        "_comment": "itg_backstop (2026-07-09 intake_triage redizayni): SAP isi FIILEN basladiginda (ilk mcp__sap-adt__* tool'u) session'da ITG-marker yoksa ITG protokolunu enjekte eder. Prompt-keyword regex'in kacirdigi talepleri deterministik yakalar. Non-blocking; native intake-triage skill + regex hook ile 3-katman.",
        "matcher": "mcp__sap-adt__.*",
        "hooks": [ { "type": "command", "command": "python", "args": ["${CLAUDE_PROJECT_DIR}/scripts/hook_shim.py", "itg_backstop"] } ]
